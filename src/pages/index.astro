    const res = document.getElementById('results');
    res.style.display = 'block';
    setTimeout(() => { res.style.opacity = "1"; res.scrollIntoView({ behavior: 'smooth' }); }, 100);
  }

  // PDF Engine
  window.downloadPDF = async function() {
    const { jsPDF } = window.jspdf;
    const el = document.getElementById('results');
    const actionButtons = document.querySelector('.blueprint-actions');
    actionButtons.style.opacity = '0';
    try {
      const canvas = await html2canvas(el, { backgroundColor: '#0f172a', scale: 2, useCORS: true });
      const imgData = canvas.toDataURL('image/png');
      const doc = new jsPDF('p', 'mm', 'a4');
      const w = doc.internal.pageSize.getWidth();
      const h = (doc.getImageProperties(imgData).height * w) / doc.getImageProperties(imgData).width;
      doc.addImage(imgData, 'PNG', 0, 0, w, h);
      doc.save(`Blueprint-${Date.now()}.pdf`);
    } finally {
      actionButtons.style.opacity = '1';
    }
  }
</script>