---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Network Blueprint Advisor | Danny Hoang">
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo">DH<span class="dot">.</span><span class="console">_</span></a>
      <div class="nav-links">
        <a href="https://github.com/dannyhng" target="_blank" class="nav-btn">View Code</a>
     </div>
    </div>
  </nav>

  <main>
    <div class="advisor-hero">
      <p class="advisor-label">Systems Architect Tool</p>
      <h1>Network <span class="highlight">Blueprint</span> Advisor</h1>
      <p class="advisor-sub">Professional-grade infrastructure recommendations based on your specific requirements and budget.</p>
      
      <div class="hero-status">
        <span class="status-meta">Infrastructure Planning</span>
        <span class="status-meta" style="margin: 0 10px;">|</span>
        <span class="status-meta">v2.5 Platinum</span>
    </div>
    </div>

    <div class="advisor-shell">
      <div class="progress-container">
        <div class="progress-bar" id="progress-bar"></div>
      </div>

      <div id="questions-container">
        <div class="question active" data-q="0">
          <div class="q-header"><span class="q-num">START</span><h2>Build your network roadmap.</h2></div>
          <p class="q-sub">Standard routers often fail under professional workloads. Answer 5 questions about your environment, and we'll design a secure, enterprise-grade blueprint tailored to your budget.</p>
          <div class="exp-box">
            <strong>What we’ll cover:</strong>
            <ul style="margin-top: 10px; padding-left: 1.2rem; color: var(--text-secondary); font-size: 0.85rem; line-height: 1.6;">
              <li><strong>Hardware Picks:</strong> Recommendations for your specific budget.</li>
              <li><strong>Security Zones:</strong> How to keep IoT and guest devices isolated.</li>
              <li><strong>L3 Routing & VPN:</strong> Professional protocols and remote access.</li>
              <li><strong>Setup Guide:</strong> A step-by-step roadmap to get you online.</li>
            </ul>
          </div>
          <button class="next-btn" onclick="nextQuestion()" style="margin-top: 2rem;">Start the Assessment →</button>
        </div>

        <div class="question" data-q="1">
          <div class="q-header"><span class="q-num">01</span><h2>Primary Objective</h2></div>
          <p class="q-sub">What is the main purpose of this infrastructure?</p>
          <div class="options-grid">
            <button class="option-card" data-key="audience" data-val="home" onclick="select(this)">
              <div class="card-title">Residential</div><p>Reliable connectivity for family and daily use.</p>
            </button>
            <button class="option-card" data-key="audience" data-val="business" onclick="select(this)">
              <div class="card-title">SMB / Enterprise</div><p>Security, uptime, and client-facing performance.</p>
            </button>
            <button class="option-card" data-key="audience" data-val="homelab" onclick="select(this)">
              <div class="card-title">Homelab / R&D</div><p>Experimentation, self-hosting, and skill development.</p>
            </button>
          </div>
        </div>

        <div class="question" data-q="2">
          <div class="q-header"><span class="q-num">02</span><h2>Hardware Budget</h2></div>
          <p class="q-sub">What is your estimated hardware expenditure?</p>
          <div class="options-grid">
            <button class="option-card" data-key="budget" data-val="low" onclick="select(this)">
              <div class="card-title">Budget (&lt;$200)</div><p>Refurbished enterprise gear or consumer hardware.</p>
            </button>
            <button class="option-card" data-key="budget" data-val="mid" onclick="select(this)">
              <div class="card-title">Mid-Tier ($200-$600)</div><p>Prosumer SDN gear (Ubiquiti, MikroTik).</p>
            </button>
            <button class="option-card" data-key="budget" data-val="high" onclick="select(this)">
              <div class="card-title">Enterprise ($1000+)</div><p>High-end Netgate or Cisco infrastructure.</p>
            </button>
          </div>
        </div>

        <div class="question" data-q="3">
          <div class="q-header"><span class="q-num">03</span><h2>Network Density</h2></div>
          <p class="q-sub">How many total endpoints (wired + wireless)?</p>
          <div class="options-grid">
            <button class="option-card" data-key="density" data-val="small" onclick="select(this)"><div class="card-title">1 - 20 Devices</div></button>
            <button class="option-card" data-key="density" data-val="medium" onclick="select(this)"><div class="card-title">21 - 60 Devices</div></button>
            <button class="option-card" data-key="density" data-val="large" onclick="select(this)"><div class="card-title">61+ Devices</div></button>
          </div>
        </div>

        <div class="question" data-q="4">
          <div class="q-header"><span class="q-num">04</span><h2>Traffic Profiles</h2></div>
          <div class="options-grid">
            <button class="option-card multi-btn" data-key="types" data-val="iot" onclick="toggleMulti(this)"><div class="card-title">IoT / Smart Home</div></button>
            <button class="option-card multi-btn" data-key="types" data-val="servers" onclick="toggleMulti(this)"><div class="card-title">NAS / Local Servers</div></button>
            <button class="option-card multi-btn" data-key="types" data-val="cameras" onclick="toggleMulti(this)"><div class="card-title">IP Surveillance</div></button>
            <button class="option-card multi-btn" data-key="types" data-val="guest" onclick="toggleMulti(this)"><div class="card-title">Guest Access</div></button>
          </div>
          <button class="next-btn" id="multi-next" onclick="nextFromMulti()" style="display:none; margin-top: 1.5rem;">Generate Architecture →</button>
		  <button class="btn-outline" onclick="skipMulti()" style="margin-top: 0.8rem; width: 100%;">
  Standard Profile (Skip) →
</button>
        </div>

        <div class="question" data-q="5">
          <div class="q-header"><span class="q-num">05</span><h2>High Availability</h2></div>
          <div class="options-grid">
            <button class="option-card" data-key="ha" data-val="yes" onclick="select(this)">
              <div class="card-title">Redundant</div><p>Dual hardware for 99.9% uptime.</p>
            </button>
            <button class="option-card" data-key="ha" data-val="no" onclick="select(this)">
              <div class="card-title">Standard</div><p>Single path is acceptable for this site.</p>
            </button>
          </div>
        </div>

        <div style="margin-top: 2rem; border-top: 1px solid var(--border); padding-top: 1rem;">
          <button id="prev-btn" onclick="prevQuestion()" style="background:none; border:none; color:var(--text-secondary); cursor:pointer; visibility:hidden; font-weight: 600;">← Previous Step</button>
        </div>
      </div>

      <div id="results" class="results-container" style="display:none">
        <div id="selection-summary" style="background: rgba(16, 185, 129, 0.05); border: 1px dashed var(--accent); padding: 12px 20px; border-radius: 6px; margin-bottom: 2rem; font-family: monospace; font-size: 0.75rem; color: var(--accent); letter-spacing: 0.5px;"></div>

        <div class="results-top">
          <div class="badge">Blueprint Generated</div>
          <h2 id="blueprint-title">System Architecture Spec</h2>
          <p id="blueprint-desc" style="color: var(--text-secondary); margin: 10px 0;"></p>
          <div class="cost-estimate">Estimated Hardware Cost: <span id="final-cost">--</span></div>
        </div>

        <div class="blueprint-grid">
          <div class="blueprint-card"><h3>01 // Hardware Stack</h3><div id="res-hardware" class="res-content"></div></div>
          <div class="blueprint-card"><h3>02 // Logical Topology</h3><div id="res-routing" class="res-content"></div></div>
          <div class="blueprint-card"><h3>03 // Routing Strategy</h3><div id="res-protocol" class="res-content"></div></div>
          <div class="blueprint-card"><h3>04 // Remote Access</h3><div id="res-remote" class="res-content"></div></div>
          <div class="blueprint-card"><h3>05 // Security Zones</h3><div id="res-vlan" class="res-content"></div></div>
          <div class="blueprint-card"><h3>06 // Deployment Roadmap</h3><div id="res-security" class="res-content"></div></div>
          
          <div class="blueprint-card" id="storage-card" style="display:none">
             <h3>07 // Storage & Data Layer</h3><div id="res-storage" class="res-content"></div>
          </div>

          <div class="blueprint-card" id="logic-card" style="grid-column: 1 / -1; border-top: 2px solid var(--accent); margin-top: 1rem;">
             <h3>08 // Why this design works</h3><div id="res-logic" class="res-content" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;"></div>
          </div>
        </div>
        
        <div class="blueprint-actions">
           <button class="btn-primary" onclick="downloadPDF()">Download PDF</button>
           <button class="btn-outline" onclick="saveResults()">Save Blueprint</button>
           <button class="btn-outline" onclick="location.reload()">Start New Blueprint</button>
        </div>

        <div class="contact-cta">
          <h3>Need a Professional Build?</h3>
          <p>I design and deploy secure, high-performance infrastructure for Homelabs and SMBs.</p>
          <div class="cta-links">
            <a href="mailto:thuvhoang19@gmail.com" class="btn-primary">Email Danny</a>
            <a href="https://linkedin.com/in/vietthuhoang/" target="_blank" class="btn-outline">LinkedIn</a>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  :root { 
    --bg-deep: #0f172a; 
    --bg-card: #1e293b; 
    --accent: #10b981; 
    --accent-glow: rgba(16, 185, 129, 0.2); 
    --text-primary: #f8fafc; 
    --text-secondary: #94a3b8; 
    --border: #334155; 
  }
  
  body { background: var(--bg-deep); color: var(--text-primary); font-family: 'Inter', sans-serif; margin: 0; overflow-x: hidden; }
  main { display: flex; flex-direction: column; align-items: center; width: 100%; }
  
  /* Navbar */
  .navbar { width: 100%; border-bottom: 1px solid var(--border); padding: 1rem 0; background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(12px); position: sticky; top: 0; z-index: 1000; }
  .nav-container { max-width: 1100px; margin: auto; display: flex; justify-content: space-between; align-items: center; padding: 0 1.5rem; }
  .nav-logo { font-weight: 800; font-size: 1.2rem; text-decoration: none; color: white; letter-spacing: -1px; }
  .dot { color: var(--accent); }
  .console { color: var(--accent); animation: blink 1s infinite; }
  @keyframes blink { 50% { opacity: 0; } }
  .nav-btn { border: 1px solid var(--accent); color: var(--accent) !important; padding: 0.4rem 1rem; border-radius: 4px; text-decoration: none; font-size: 0.85rem; }

  /* Hero Section */
  .advisor-hero { text-align: center; min-height: 40vh; display: flex; flex-direction: column; justify-content: center; padding: 4rem 1.5rem 6rem; }
  .advisor-label { color: var(--accent); font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 1rem; }
  .advisor-hero h1 { font-size: 3.5rem; font-weight: 800; margin: 0; letter-spacing: -2px; line-height: 1.1; }
  .highlight { color: var(--accent); }
  .advisor-sub { color: var(--text-secondary); max-width: 600px; margin: 1rem auto; line-height: 1.6; font-size: 1.1rem; }
  .hero-status { display: flex; justify-content: center; gap: 1rem; margin-top: 2rem; font-family: monospace; font-size: 0.7rem; }

  /* Main Shell */
  .advisor-shell { width: 92%; max-width: 950px; margin: -4rem auto 6rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 3rem; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); box-sizing: border-box; }
  .progress-container { background: var(--border); height: 4px; border-radius: 2px; margin-bottom: 3rem; overflow: hidden; }
  .progress-bar { background: var(--accent); height: 100%; width: 0%; transition: 0.4s; }

  /* Questions */
  .question { display: none; }
  .question.active { display: block; animation: slideUp 0.4s ease-out; }
  @keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .q-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem; }
  .q-num { font-family: monospace; color: var(--accent); font-size: 1.1rem; font-weight: bold; }
  .question h2 { font-size: 1.6rem; margin: 0; font-weight: 700; }
  .q-sub { color: var(--text-secondary); margin-bottom: 2rem; font-size: 0.95rem; }

  /* Options */
  .options-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
  .option-card { background: #0f172a; border: 1px solid var(--border); padding: 1.2rem; border-radius: 8px; text-align: left; cursor: pointer; transition: 0.2s; color: var(--text-primary); width: 100%; box-sizing: border-box; }
  .option-card:hover { border-color: var(--accent); background: #1e293b; }
  .option-card.selected { border-color: var(--accent); background: var(--accent-glow); }
  .card-title { font-weight: 700; font-size: 1rem; margin-bottom: 0.4rem; }
  .next-btn { margin-top: 2rem; background: var(--accent); color: var(--bg-deep); border: none; padding: 1rem; border-radius: 6px; font-weight: 800; cursor: pointer; width: 100%; transition: 0.2s; }
  .next-btn:hover { opacity: 0.9; transform: translateY(-1px); }

  /* Results Grid */
  .results-top { border-bottom: 1px solid var(--border); padding-bottom: 2rem; margin-bottom: 2rem; }
  .badge { display: inline-block; background: var(--accent-glow); color: var(--accent); font-size: 0.65rem; font-weight: 800; padding: 4px 12px; border-radius: 99px; text-transform: uppercase; margin-bottom: 1rem; border: 1px solid var(--accent); }
  .cost-estimate { display: inline-block; background: var(--accent-glow); color: var(--accent); padding: 0.5rem 1rem; border-radius: 4px; font-weight: 700; font-size: 0.9rem; }
  .blueprint-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.2rem; }
  .blueprint-card { background: #0f172a; border-left: 3px solid var(--accent); padding: 1.2rem; border-radius: 4px; }
  .blueprint-card h3 { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--accent); margin: 0 0 0.8rem; }
  .res-content { font-size: 0.85rem; line-height: 1.6; color: var(--text-secondary); }
  .res-content strong { color: white; }
  .exp-box { background: rgba(255,255,255,0.03); padding: 0.8rem; border-radius: 4px; margin-top: 1rem; font-size: 0.75rem; border: 1px dashed var(--border); line-height: 1.5; }

  /* Buttons */
  .blueprint-actions { margin-top: 3rem; display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary { background: var(--accent); color: var(--bg-deep); border: none; padding: 0.8rem 1.5rem; border-radius: 4px; font-weight: 700; cursor: pointer; text-decoration: none; flex: 1; text-align: center; font-size: 0.9rem; }
  .btn-outline { background: transparent; border: 1px solid var(--border); color: white; padding: 0.8rem 1.5rem; border-radius: 4px; cursor: pointer; text-decoration: none; transition: 0.2s; flex: 1; text-align: center; font-size: 0.9rem; }

  /* Mobile Adjustments */
  .cta-links { display: flex; justify-content: center; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap; }
  @media (max-width: 768px) {
    .advisor-hero { padding: 2rem 1rem; min-height: 30vh; }
    .advisor-shell { padding: 1.5rem; margin: 1rem auto; width: 95%; } /* Removed negative margin */
    .blueprint-grid { grid-template-columns: 1fr; }
    .blueprint-actions, .cta-links { flex-direction: column; } /* Stacks both sets of buttons */
    .btn-primary, .btn-outline { width: 100%; }
    #blueprint-title { font-size: 1.4rem; }
    
    /* Make the summary bar items smaller and stacked on mobile */
    #selection-summary div { font-size: 0.75rem; width: 100%; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 5px; }
  }

</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<script is:inline>
  const answers = {};
  const multiSelections = new Set();
  let currentQ = 0;
  const totalQ = 5;

  // Persist Data Logic
  const saved = localStorage.getItem('networkBlueprint');
  if (saved) {
  Object.assign(answers, JSON.parse(saved));
  // Do NOT auto-show results
}

  window.select = function(btn) {
    const key = btn.dataset.key;
    const val = btn.dataset.val;
    answers[key] = val;
    btn.parentElement.querySelectorAll('.option-card').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    setTimeout(() => nextQuestion(), 400);
  }

  window.toggleMulti = function(btn) {
    const val = btn.dataset.val;
    multiSelections.has(val) ? multiSelections.delete(val) : multiSelections.add(val);
    btn.classList.toggle('selected');
    document.getElementById('multi-next').style.display = multiSelections.size > 0 ? 'block' : 'none';
  }

  window.nextFromMulti = function() {
    answers['types'] = Array.from(multiSelections);
    nextQuestion();
  }

  window.skipMulti = function() {
  answers['types'] = [];
  nextQuestion();
}

  function nextQuestion() {
    if (currentQ >= totalQ) { showResults(); return; }
    document.querySelector(`.question[data-q="${currentQ}"]`).classList.remove('active');
    currentQ++;
    document.querySelector(`.question[data-q="${currentQ}"]`).classList.add('active');
    updateNavUI();
  }

  window.prevQuestion = function() {
    if (currentQ <= 0) return;
    document.querySelector(`.question[data-q="${currentQ}"]`).classList.remove('active');
    currentQ--;
    document.querySelector(`.question[data-q="${currentQ}"]`).classList.add('active');
    updateNavUI();
  }

  function updateNavUI() {
    const progress = currentQ === 0 ? 0 : (currentQ / totalQ) * 100;
    document.getElementById('progress-bar').style.width = progress + '%';
    document.getElementById('prev-btn').style.visibility = currentQ > 0 ? 'visible' : 'hidden';
  }

  window.saveResults = function() {
    localStorage.setItem('networkBlueprint', JSON.stringify(answers));
    alert('Blueprint locally cached for session persistence.');
  }

  function showResults() {
	document.querySelector('.advisor-hero').style.display = 'none'; 
    document.getElementById('questions-container').style.display = 'none';
    document.querySelector('.progress-container').style.display = 'none';
    
    const r = answers;
    const types = r.types || [];
    const isLab = r.audience === 'homelab';
    const isBiz = r.audience === 'business';
    const hasHA = r.ha === 'yes' && r.budget === 'high';

const haWarning = (r.ha === 'yes' && r.budget !== 'high')
  ? `<div class="exp-box"><strong>Note:</strong> True high availability needs a higher budget. A backup (cold spare) setup is recommended instead.</div>`
  : "";

    // Summary Bar
    // 1. Clean Selection Summary (Replaces the Architect Log)
    // 1. Clean Selection Summary (Compact Design)
    const audienceMap = { home: 'Residential', business: 'Enterprise/SMB', homelab: 'R&D Homelab' };
    const budgetMap = { low: '< $200', mid: '$200 - $600', high: '$1,000+' };
    const densityMap = { small: '1-20 Devices', medium: '21-60 Devices', large: '61+ Devices' };

    // Using a simpler Grid-like layout for the summary
    const sumHtml = `
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.8rem; width: 100%;">
        <div><strong style="color:var(--accent)">Env:</strong> ${audienceMap[r.audience]}</div>
        <div><strong style="color:var(--accent)">Budget:</strong> ${budgetMap[r.budget]}</div>
        <div><strong style="color:var(--accent)">Nodes:</strong> ${densityMap[r.density]}</div>
        <div><strong style="color:var(--accent)">HA:</strong> ${hasHA ? 'Enabled' : 'No'}</div>
      </div>
    `;
    document.getElementById('selection-summary').innerHTML = sumHtml;
    
    // Style adjustments for a cleaner "Receipt" look
    const summaryBar = document.getElementById('selection-summary');
    summaryBar.style.border = "1px solid var(--border)";
    summaryBar.style.background = "rgba(16, 185, 129, 0.03)";
    summaryBar.style.padding = "1rem";
    summaryBar.style.fontFamily = "inherit"; 
    summaryBar.style.fontSize = "0.8rem";
    summaryBar.style.marginBottom = "1.5rem";

    // IMPORTANT: Reset the margin of the shell so it's not "too high"
    const shell = document.querySelector('.advisor-shell');
    shell.style.marginTop = "2rem";

    // Header & Descriptive Logic
    document.getElementById('blueprint-title').textContent = `${audienceMap[r.audience]} Specification`;
    document.getElementById('blueprint-desc').innerHTML = `Custom multi-zone topology for <strong>${r.density} endpoints</strong>. Optimized for <strong>${hasHA ? 'high availability' : 'strong network isolation'}</strong>.`;
    document.getElementById('final-cost').textContent = { low: '$150-$400', mid: '$600-$1,200', high: '$2,500+' }[r.budget];

    // Hardware
    let hw = "";
    if (r.budget === 'high') {
  hw = `<strong>Edge:</strong> Netgate 6100 ${hasHA ? 'HA Pair' : '(Standalone)'}<br/>
        <strong>Core:</strong> Cisco Catalyst 9200L (L3 Managed)<br/>
        <strong>WLAN:</strong> 2x UniFi U7 Pro (Wi-Fi 7 / 6GHz)`;
} else if (r.budget === 'mid') {
      hw = `<strong>Gateway:</strong> UniFi Cloud Gateway Max<br/><strong>Switch:</strong> UniFi Pro Max 16 PoE<br/><strong>Wireless:</strong> 2x UniFi U7 Pro`;
    } else {
      hw = `<strong>Gateway:</strong> x86 Mini PC (OPNsense)<br/><strong>Switch:</strong> TP-Link L2 Managed<br/><strong>Wireless:</strong> TP-Link Omada AP`;
    }
    hw += `<div class="exp-box"><strong>Interconnect:</strong> Use <strong>${r.budget === 'high'
  ? '10Gbps SFP+ DAC (if supported)'
  : 'Cat6 Ethernet'}</strong> for the switch-to-firewall link.</div>`;
    document.getElementById('res-hardware').innerHTML = hw;

    // Topology
    document.getElementById('res-routing').innerHTML = `
  ${haWarning}
  <div class="topology-simple">
    <div class="top-section"><strong>WAN EDGE</strong></div><div class="arrow">↓</div>
    <div class="top-section"><strong>SECURITY</strong><br/>(${hasHA ? 'HA CLUSTER' : 'FIREWALL'})</div><div class="arrow">↓</div>
    <div class="top-section"><strong>BACKBONE</strong><br/>(Tagged Trunk)</div>
  </div>`;

    // Routing Logic (New)
    const useL3Offload = (
  r.budget === 'high' &&
  r.density === 'large'
);
    
    document.getElementById('res-protocol').innerHTML = `
      <strong>Method:</strong> ${useL3Offload ? 'L3 Hardware Offloading' : 'Router-on-a-Stick (RoAS)'}<br/>
      <div class="exp-box">
        <strong>Logic:</strong> ${useL3Offload 
          ? 'Inter-VLAN routing is handled at the switch using SVIs, keeping the Firewall CPU free for security inspection.' 
          : 'All inter-VLAN traffic is processed by the Gateway. Simple to manage and perfect for your current device density.'}
      </div>`;

    // Remote Access (New)
    const remoteAccessNeeded = (types.includes('servers') || types.includes('cameras') || r.audience === 'business');
    
    document.getElementById('res-remote').innerHTML = remoteAccessNeeded
      ? `<strong>VPN:</strong> ${
  r.budget === 'low' 
    ? 'Tailscale (simplest setup)' 
    : 'WireGuard (self-hosted)'
}<br/>
         <p style="font-size:0.8rem; margin-top:5px;">Secure entry for off-site access to your ${types.includes('cameras') ? 'camera system' : 'internal resources'}.</p>`
      : `<strong>Status:</strong> Internal Only<br/>
         <p style="font-size:0.8rem; margin-top:5px;">No external ports opened. Maximum security for a local-only environment.</p>`;

    // VLANs & Security
